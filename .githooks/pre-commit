#!/bin/sh
# Auto-run rustfmt before committing. Formats and re-stages Rust files.

set -eu

if ! command -v cargo >/dev/null 2>&1; then
  echo "cargo not found; skipping rustfmt" >&2
  exit 0
fi

# Format all workspace members
if ! cargo fmt --all; then
  echo "cargo fmt failed; aborting commit" >&2
  exit 1
fi

# Re-stage changed Rust files so the commit includes formatting updates.
# Note: This may override partial staging for Rust files.
changed_rs=$(git ls-files -m '*.rs' || true)
if [ -n "${changed_rs}" ]; then
  # shellcheck disable=SC2086
  git add -- ${changed_rs}
fi

exit 0
